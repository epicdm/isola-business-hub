# ITER-15: BFF API access for Isola settings persistence.
# Copy this file to .env.local and fill in the values.

# BFF v2 base URL (the deepseek server that runs the Isola backend)
VITE_BFF_API_URL=https://bff.epic.dm

# Internal secret used for /api/internal/* endpoints (dev-only; will be
# replaced with a proper tenant-auth flow post-MVP).
# WARNING: this value is exposed in the client bundle — do not commit a real
# secret to the repo. Use a dev-only value here and rotate in production.
VITE_BFF_INTERNAL_SECRET=replace-with-internal-secret

# Tenant's BFF agent UUID. For MVP tenant-zero (EPIC), this is Eric's agent.
# Later this comes from the signed-in user's session instead of env.
VITE_DEFAULT_AGENT_ID=8166ea11-8db0-4f26-879a-e2067be0a018
